# ==============================================================================
# GENERIC CHURN AGENT: CONFIGURATION TEMPLATE
# Instructions: Copy this file, rename it to '.env', and replace the dummy 
# values below with your actual Google Cloud project and database details.
# ==============================================================================

# --- GCP INFRASTRUCTURE ---
GOOGLE_CLOUD_PROJECT=your-actual-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# --- BIGQUERY DATABASE MAPPING (STRUCTURED DATA) ---
# Replace these with the exact names of your dataset and table
BQ_PROJECT_ID=your-actual-gcp-project-id
BQ_DATASET_ID=your_actual_dataset_name
BQ_TABLE_ID=your_actual_table_name

# --- COLUMN MAPPING (CRITICAL) ---
# The agent will dynamically read these columns. You MUST change these to match
# the actual column headers in your BigQuery table.
BQ_IDENTIFIER_COLUMN=company_name 
BQ_METRIC_COLUMNS=monthly_spend_usd, usage_drop_30d_percentage

# --- CLOUD STORAGE MAPPING (UNSTRUCTURED DATA) ---
GCS_TICKETS_BUCKET=your-bucket-name

# --- AGENT PERSONA & GOAL ---
AGENT_ROLE="You are an enterprise Customer Success Agent."
AGENT_OBJECTIVE="Your goal is to assess churn risk, synthesize structured and unstructured data, and draft retention strategies."
